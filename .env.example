POLYGON_API_KEY=your_polygon_api_key
ALPHAVANTAGE_API_KEY=your_alpha_vantage_api_key

# Futu OpenD runs locally. Keep these defaults unless you changed OpenD settings.
FUTU_OPEND_HOST=127.0.0.1
FUTU_OPEND_PORT=11111

# Optional delivery by Resend email API.
RESEND_API_KEY=
REPORT_FROM=LEAP Watch <reports@yourdomain.com>
REPORT_TO=you@example.com

# Optional delivery by a generic webhook, such as Discord, Slack, n8n, Make, or your own endpoint.
REPORT_WEBHOOK_URL=

# Optional AI analysis layer. OpenAI-compatible chat completions endpoint.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_USE_RESPONSES=1
STOCK_AGENT_PRESET=tradingagents
STOCK_AGENT_REFERENCE=TauricResearch/TradingAgents

# After-close automation in npm start. Time is America/New_York.
AUTO_SCAN_ENABLED=1
AUTO_SCAN_TIME_ET=16:30
AUTO_PREMARKET_ENABLED=1
AUTO_PREMARKET_TIME_ET=08:30
FUTU_OPTION_SCREEN_CONTRACTS=500
FUTU_MAX_SYMBOLS=5
FUTU_MIN_EXPIRATIONS_OPTION_VOLUME=12
FUTU_LEAP_EXPIRATIONS_OPTION_VOLUME=8
FUTU_INCLUDE_ETF_OPTIONS=0
FUTU_EXCLUDE_OPTION_UNDERLYINGS=SPY,QQQ,IWM,DIA,TQQQ,SQQQ,SPX,SPXW,NDX,RUT,VIX
